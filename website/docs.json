{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Lighter MCP",
  "description": "Portable Model Context Protocol server for Lighter — wraps the agent kit with safety, audit, and adapters for Cursor, Claude, Codex, and any MCP client.",
  "colors": {
    "primary": "#0A0A0F",
    "light": "#FFFFFF",
    "dark": "#FFFFFF"
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo/lighter.png",
    "dark": "/logo/lighter.png",
    "href": "/"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "background": {
    "color": {
      "dark": "#0A0A0F",
      "light": "#FFFFFF"
    }
  },
  "fonts": {
    "heading": {
      "family": "Inter"
    },
    "body": {
      "family": "Inter"
    }
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": "dark"
  },
  "navbar": {
    "links": [
      {
        "label": "Lighter app",
        "href": "https://app.lighter.xyz"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/iamgoatedaf/lighter-mcp"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "get-started/what-is-lighter-mcp",
              "get-started/installation",
              "get-started/quickstart",
              "get-started/configuration",
              "get-started/modes-and-safety"
            ]
          },
          {
            "group": "Agent adapters",
            "pages": [
              "adapters/overview",
              "adapters/cursor",
              "adapters/claude-code",
              "adapters/claude-desktop",
              "adapters/codex",
              "adapters/openclaw",
              "adapters/generic"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/first-paper-trade",
              "guides/guarded-live-order",
              "guides/funding-scan",
              "guides/price-alerts"
            ]
          },
          {
            "group": "Security",
            "pages": [
              "security/threat-model",
              "security/disclaimer"
            ]
          }
        ]
      },
      {
        "tab": "Tools",
        "groups": [
          {
            "group": "Overview",
            "pages": ["tools/overview", "tools/diagnostics"]
          },
          {
            "group": "Read-only",
            "pages": ["tools/read"]
          },
          {
            "group": "Paper",
            "pages": ["tools/paper"]
          },
          {
            "group": "Live",
            "pages": ["tools/live"]
          },
          {
            "group": "Funds",
            "pages": ["tools/funds"]
          }
        ]
      },
      {
        "tab": "Internals",
        "groups": [
          {
            "group": "Architecture",
            "pages": [
              "reference/error-envelope",
              "reference/safety",
              "reference/confirmations",
              "reference/audit-log"
            ]
          },
          {
            "group": "CLI",
            "pages": ["reference/cli"]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/iamgoatedaf/lighter-mcp",
      "x": "https://x.com/lighter_xyz"
    }
  },
  "seo": {
    "metatags": {
      "og:type": "website",
      "og:site_name": "Lighter MCP",
      "og:image": "/logo/dark.svg",
      "twitter:card": "summary_large_image"
    }
  },
  "search": {
    "prompt": "Search docs..."
  }
}
