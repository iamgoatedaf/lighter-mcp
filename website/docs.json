{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Lighter MCP",
  "description": "Portable Model Context Protocol server that exposes Lighter trading to any MCP-capable agent — Cursor, Claude, Codex, and more — with safety as a first-class concern.",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#5B21B6"
